<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:fontFamily="clr-namespace:PlanShare.App.Constants">
    
    <Style TargetType="Button">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HeightRequest" Value="60" />
        <Setter Property="FontFamily" Value="{Static fontFamily:FontFamily.MAIN_FONT_BLACK}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
    </Style>

    <Style x:Key="ButtonGoogleLogin" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource WhiteDark}" />
        <Setter Property="TextColor" Value="Black" />
    </Style>
    
    <Style x:Key="ButtonCreateUser" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BlueDark}, Dark={StaticResource BlueLight}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
    </Style>
    
    <Style x:Key="ButtonCode" TargetType="Button">
        <Setter Property="WidthRequest" Value="25" />
        <Setter Property="HeightRequest" Value="25" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource GreyLight}, Dark={StaticResource Blue}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
    </Style>
    
</ResourceDictionary>