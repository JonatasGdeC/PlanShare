<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:fontFamily="clr-namespace:PlanShare.App.Constants">

    <Style TargetType="Button">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HeightRequest" Value="60" />
        <Setter Property="FontFamily" Value="{Static fontFamily:FontFamily.MAIN_FONT_BLACK}" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding 
                        Light={StaticResource PRIMARY_COLOR_LIGHT}, 
                        Dark={StaticResource PRIMARY_COLOR_DARK}}" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding 
                        Light={StaticResource SECONDARY_COLOR_LIGHT}, 
                        Dark={StaticResource SECONDARY_COLOR_DARK}}" />
    </Style>

    <Style x:Key="ButtonGoogleLogin" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#F6F6FB" />
        <Setter Property="TextColor" Value="Black" />
    </Style>

    <Style x:Key="ButtonCreateUser" TargetType="Button">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding 
                        Light={StaticResource HIGHLIGHT_COLOR_LIGHT}, 
                        Dark={StaticResource HIGHLIGHT_COLOR_DARK}}" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding 
                        Light={StaticResource SECONDARY_COLOR_LIGHT}, 
                        Dark={StaticResource SECONDARY_COLOR_DARK}}" />
    </Style>

    <Style x:Key="ButtonCode" TargetType="Button">
        <Setter Property="WidthRequest" Value="25" />
        <Setter Property="HeightRequest" Value="25" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding 
                        Light={StaticResource KEYBOARD_COLOR_LIGHT}, 
                        Dark={StaticResource KEYBOARD_COLOR_DARK}}" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding 
                        Light={StaticResource PRIMARY_COLOR_LIGHT}, 
                        Dark={StaticResource PRIMARY_COLOR_DARK}}" />
    </Style>

</ResourceDictionary>