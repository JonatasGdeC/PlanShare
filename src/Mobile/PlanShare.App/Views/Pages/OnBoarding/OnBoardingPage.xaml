<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlanShare.App.Views.Pages.OnBoarding.OnBoarding">
    <VerticalStackLayout>
        <Image Source="hero_image.png"/>
        
        <Label Text="Tarefas pequenas, grandes resultados." 
               Style="{StaticResource Title}"
               HorizontalOptions="Center"/>

        <Button Text="Continuar com o Google" 
                Style="{StaticResource ButtonGoogleLogin}" 
                ImageSource="google_icon.png" 
                Margin="0,40,0,20"/>
        
        <Button Text="Login com Email e Senha" 
                Margin="0,0,0,40"/>

        <HorizontalStackLayout HorizontalOptions="Center">
            <Label Text="Não tem uma conta? "/>
            <Label Text="Crie a sua conta!" Style="{StaticResource HighLight}"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>