<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:component="clr-namespace:PlanShare.App.Views.Components.Input;assembly=PlanShare.App"
             x:Class="PlanShare.App.Views.Pages.Login.DoLogin.DoLoginPage">
    <VerticalStackLayout>
        <Label Text="Login" Style="{StaticResource Title}"/>

        <component:InputComponent 
            Title="Email" 
            Placeholder="email@email.com" 
            Keyboard="Email"
            Margin="0,40,0,30"/>

        <component:InputPasswordComponent/>
        
        <Label Text="Esqueceu sua Senha?" Style="{StaticResource HighLight}"
               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
               Margin="0,40,0,70" HorizontalOptions="End"/>
        
        <Button Text="Login"/>
    </VerticalStackLayout>
</ContentPage>